<Page x:Class="GBDD.Pages.CarCardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GBDD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="780" d:DesignWidth="900"
      Title="CarCardPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,15,0" Background="#F5F7FA">
        <StackPanel Margin="20">

            <DockPanel Margin="0,0,0,20">
                <TextBlock Text="Карточка эвакуированного ТС" Style="{StaticResource TitleText}"></TextBlock>
                <Border x:Name="brdStatus" Style="{StaticResource WidgetStyle}" Padding="12,6" CornerRadius="6" Background="#E3F2FD" 
                        DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="lblStatus" FontWeight="Bold" Foreground="#1565C0"></TextBlock>
                </Border>
                <TextBlock x:Name="lblPlate" Style="{StaticResource TitleText}" Margin="15,0,0,0" VerticalAlignment="Center"></TextBlock>
            </DockPanel>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"></ColumnDefinition>
                    <ColumnDefinition Width="1.5*"></ColumnDefinition>
                </Grid.ColumnDefinitions>


                <Border Style="{StaticResource CardStyle}" Grid.Column="0" Height="460">
                    <StackPanel>
                        <TextBlock Text="Фото траспорта" Style="{StaticResource LabelText}" Margin="10,0,0,10"></TextBlock>
                        
                        <ScrollViewer VerticalScrollBarVisibility="Auto" Height="260">
                            <ItemsControl x:Name="icPhotos">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel ItemWidth="140" ItemHeight="160"></WrapPanel>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Width="120" Margin="4">
                                            <Border BorderBrush="#E3F2FD" BorderThickness="1" CornerRadius="4" Background="White" Height="120" ClipToBounds="True"
                                                    Cursor="Hand" MouseLeftButtonUp="Photo_Click" Tag="{Binding FilePath}">
                                                
                                                <Image Source="{Binding ImageSource}" Stretch="Uniform"></Image>
                                            </Border>

                                            <Button Content="Удалить"  Width="100" Height="24" Background="#FFEBEE" Foreground="#E53935" 
                                                    BorderBrush="#E53935" BorderThickness="1" FontSize="10" Margin="0,4,0,0" 
                                                    HorizontalAlignment="Center" ToolTip="Удалить фото" Click="DeletePhoto_Click" Tag="{Binding PhotoId}"></Button>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <TextBlock x:Name="lblNoPhotos" Text="Фото не загружены" Foreground="#90A4AE"  FontSize="12" HorizontalAlignment="Center" 
                                   VerticalAlignment="Center" Margin="0,20,0,0" Visibility="Collapsed"></TextBlock>

                        <Button Content="Добавить фото" Style="{StaticResource PrimaryButtonStyle}"  Height="35" Margin="40,10,40,10" Click="AddPhoto_Click"></Button>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Column="1" Margin="15,0,0,0">

                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Данные транспортного средства" Style="{StaticResource LabelText}" Margin="0,0,0,12"></TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="Госномер" Style="{StaticResource LabelText}"></TextBlock>
                                    <TextBlock x:Name="lblPlateDetail" Style="{StaticResource ValueText}" FontSize="16" FontWeight="Bold"></TextBlock>
                                    
                                    <TextBlock Text="VIN-номер" Style="{StaticResource LabelText}"></TextBlock>
                                    <TextBlock x:Name="lblVin" Style="{StaticResource ValueText}" FontSize="14" TextWrapping="Wrap"></TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <TextBlock Text="Категория / Цвет" Style="{StaticResource LabelText}"></TextBlock>
                                    <TextBlock x:Name="lblCatColor" FontSize="14" Foreground="#333333"></TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Марка / Модель" Style="{StaticResource LabelText}"></TextBlock>
                                    <TextBlock x:Name="lblMakeModel" FontSize="14" Foreground="#333333"></TextBlock>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                        <StackPanel>
                            <TextBlock Text="Владелец ТС" Style="{StaticResource LabelText}" Margin="0,0,0,12"></TextBlock>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                    <ColumnDefinition Width="*"></ColumnDefinition>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                    <TextBlock Text="ФИО" Style="{StaticResource LabelText}"></TextBlock>
                                    <TextBlock x:Name="lblOwnerName" FontSize="13" Foreground="#333333"></TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="1" Margin="5,0">
                                    <TextBlock Text="Телефон" Style="{StaticResource LabelText}"></TextBlock>
                                    <TextBlock x:Name="lblOwnerPhone" FontSize="13" Foreground="#333333"></TextBlock>
                                </StackPanel>
                                <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                    <TextBlock Text="Паспорт / ВУ" Style="{StaticResource LabelText}"></TextBlock>
                                    <TextBlock x:Name="lblOwnerDocs" FontSize="12" Foreground="#546E7A" TextWrapping="Wrap"></TextBlock>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0" Background="#F0F4F8" BorderBrush="#1976D2" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text=" Время на стоянке и Стоимость" Style="{StaticResource LabelText}" Margin="0,0,0,10"></TextBlock>

                            <DockPanel Margin="0,0,0,8">
                                <TextBlock Text="На стоянке:" DockPanel.Dock="Left" FontSize="13" Foreground="#546E7A" VerticalAlignment="Center"></TextBlock>
                                <TextBlock x:Name="lblTimer" DockPanel.Dock="Right" Style="{StaticResource ValueText}" Foreground="#1565C0"></TextBlock>
                            </DockPanel>

                            <TextBlock x:Name="lblTariffInfo" FontSize="11" Foreground="#78909C" Margin="0,0,0,5"></TextBlock>

                            <Separator Margin="0,5"/>

                            <DockPanel Margin="0,8,0,0">
                                <TextBlock Text="Итого к оплате:" DockPanel.Dock="Left" FontSize="14" FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"></TextBlock>
                                <TextBlock x:Name="lblTotalCost" DockPanel.Dock="Right" Style="{StaticResource ValueText}" Foreground="#D32F2F" FontSize="26"></TextBlock>
                            </DockPanel>
                        </StackPanel>
                    </Border>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Назад к реестру" Style="{StaticResource PrimaryButtonStyle}" Background="#757575" Width="160" Margin="0,0,10,0" Click="Back_Click"></Button>
                        <Button x:Name="btnRelease" Content="Выдать автомобиль" Style="{StaticResource SuccessButtonStyle}" Width="180" Click="ReleaseCar_Click" Visibility="Collapsed"></Button>
                    </StackPanel>
                </StackPanel>
            </Grid>


            
            <Border Style="{StaticResource CardStyle}" Margin="0,10,0,0">
                <StackPanel>
                    <TextBlock Text="Акт осмотра и комплектация" Style="{StaticResource LabelText}" Margin="0,0,0,12"></TextBlock>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="Auto"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,15,0">
                            <TextBlock Text="Отмеченные повреждения:" Style="{StaticResource LabelText}" Margin="0,0,0,8"></TextBlock>
                            <ListBox x:Name="lstDamages" BorderThickness="0" Background="Transparent" MaxHeight="120">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontSize="12" Padding="2,3"></TextBlock>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </StackPanel>

                        <Rectangle Grid.Column="1" Width="1" Fill="#E3F2FD" Margin="10,0"></Rectangle>

                        <StackPanel Grid.Column="2" Margin="15,0,0,0">
                            <TextBlock Text="Комплектация при заезде:" Style="{StaticResource LabelText}" Margin="0,0,0,8"></TextBlock>
                            <StackPanel x:Name="spChecklistView"></StackPanel>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            
        </StackPanel>
    </ScrollViewer>
</Page>
