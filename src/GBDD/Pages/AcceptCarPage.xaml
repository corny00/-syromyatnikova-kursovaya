<Page x:Class="GBDD.Pages.AcceptCarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GBDD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1100" d:DesignWidth="900"
      Title="AcceptCarPage">

    <Grid Background="#F5F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="20,15,20,10">
            <TextBlock Text="Прием автомобиля" Style="{StaticResource TitleText}"></TextBlock>
            <TextBlock x:Name="lblMode" Text="Оформление нового поступления" Style="{StaticResource SubtitleText}"></TextBlock>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0,0,15,0">
            <StackPanel Margin="20,0,20,20">

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Данные транспортного средства" Style="{StaticResource TitleText}" Margin="0,0,0,12"></TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Госномер" Style="{StaticResource LabelText}"></TextBlock>
                                <TextBox x:Name="txtPlate" Style="{StaticResource InputTextBoxStyle}" Height="32" Margin="0,0,0,10"></TextBox>

                                <TextBlock Text="VIN-номер" Style="{StaticResource LabelText}"></TextBlock>
                                <TextBox x:Name="txtVin" Style="{StaticResource InputTextBoxStyle}" Height="32"></TextBox>
                            </StackPanel>


                            <StackPanel Grid.Column="1" Margin="5,0">
                                <TextBlock Text="Категория" Style="{StaticResource LabelText}"></TextBlock>
                                <ComboBox x:Name="cmbCategory" Style="{StaticResource InputComboBoxStyle}" Height="32" Margin="0,0,0,10" 
                                          DisplayMemberPath="Code" SelectedValuePath="CategoryId"></ComboBox>

                                <TextBlock Text="Марка" Style="{StaticResource LabelText}"/>
                                <ComboBox x:Name="cmbMake" Style="{StaticResource InputComboBoxStyle}" Height="32" Margin="0,0,0,10" DisplayMemberPath="MakeName" 
                                          SelectedValuePath="MakeId" SelectionChanged="cmbMake_SelectionChanged"></ComboBox>

                                <TextBlock Text="Цвет" Style="{StaticResource LabelText}"/>
                                <ComboBox x:Name="cmbColor" Style="{StaticResource InputComboBoxStyle}" Height="32" DisplayMemberPath="ColorName" SelectedValuePath="ColorId"></ComboBox>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="Модель" Style="{StaticResource LabelText}"/>
                                <ComboBox x:Name="cmbModel" Style="{StaticResource InputComboBoxStyle}" Height="32" DisplayMemberPath="ModelName" SelectedValuePath="ModelId"></ComboBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Основание задержания" Style="{StaticResource TitleText}" Margin="0,0,0,12"></TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Номер протокола" Style="{StaticResource LabelText}"/>
                                <TextBox x:Name="txtProtocol" Style="{StaticResource InputTextBoxStyle}" Height="32"></TextBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5,0">
                                <TextBlock Text="Статья КоАП" Style="{StaticResource LabelText}"/>
                                <TextBox x:Name="txtArticle" Style="{StaticResource InputTextBoxStyle}" Height="32"></TextBox>
                                
                                
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="10,0,0,0">
                                <TextBlock Text="Инспектор ГИБДД" Style="{StaticResource LabelText}"/>
                                <ComboBox x:Name="cmbInspector" Style="{StaticResource InputComboBoxStyle}" Height="32" DisplayMemberPath="FullName" SelectedValuePath="UserId"></ComboBox>
                               
                                <TextBlock Text="Владелец ТС" Style="{StaticResource LabelText}"/>
                                <ComboBox x:Name="cmbOwner" Style="{StaticResource InputComboBoxStyle}" Height="32" DisplayMemberPath="FullName" SelectedValuePath="OwnerId"></ComboBox>
                            </StackPanel>
                            
                           
                        </Grid>
                    </StackPanel>
                </Border>
                
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Эвакуатор" Style="{StaticResource TitleText}" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="Эвакуатор" Style="{StaticResource LabelText}"/>
                                <ComboBox x:Name="cmbTowTruck" Style="{StaticResource InputComboBoxStyle}" Height="32" SelectedValuePath="TowTruckId"  
                                          SelectionChanged="CmbTowTruck_SelectionChanged">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding PlateNumber}" FontWeight="SemiBold" Margin="0,0,8,0"></TextBlock>
                                                <TextBlock Text="{Binding DriverName}" Foreground="#78909C"></TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Водитель эвакуатора" Style="{StaticResource LabelText}"></TextBlock>
                                <TextBox x:Name="txtTowDriver" Style="{StaticResource InputTextBoxStyle}" Height="32" IsReadOnly="True" Background="#F5F5F5"></TextBox>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

  
                <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Осмотр повреждений и комплектация" Style="{StaticResource TitleText}" Margin="0,0,0,12"></TextBlock>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="Auto"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>


                            <StackPanel Grid.Column="0" Margin="0,0,15,0">
                                <TextBlock Text="Отметьте зоны с повреждениями:" Style="{StaticResource LabelText}" Margin="0,0,0,8"></TextBlock>
                                <UniformGrid x:Name="ugDamageZones" Columns="3" Rows="3" Width="240" Height="240" HorizontalAlignment="Left">
                                    
                                </UniformGrid>
                                <TextBlock Text="Кликните для выбора/снятия" FontSize="10" Foreground="#90A4AE" Margin="0,5,0,0"></TextBlock>
                            </StackPanel>


                            <Rectangle Grid.Column="1" Width="1" Fill="#E3F2FD" Margin="10,0"/>

                            <StackPanel Grid.Column="2" Margin="15,0,0,0">
                                <TextBlock Text="Комплектация ТС:" Style="{StaticResource LabelText}" Margin="0,0,0,8"></TextBlock>
                                <StackPanel x:Name="spChecklist"></StackPanel>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,10,20,20">
            <Button Content="Отмена" Style="{StaticResource PrimaryButtonStyle}" Background="#757575" Width="120" Margin="0,0,10,0" Click="Cancel_Click"></Button>
            <Button x:Name="btnSave" Content="Сохранить" Style="{StaticResource SuccessButtonStyle}" Width="150" Click="Save_Click"></Button>
        </StackPanel>
    </Grid>
</Page>
