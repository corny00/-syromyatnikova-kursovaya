<Page x:Class="GBDD.Pages.ReleaseCarPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GBDD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="700" d:DesignWidth="800"
      Title="ReleaseCarPage">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,15,0" Background="#F5F7FA">
        <StackPanel Margin="20" MaxWidth="700" HorizontalAlignment="Center">

            <TextBlock Text="Оформление выдачи ТС" Style="{StaticResource TitleText}" Margin="0,0,0,5"></TextBlock>
            <TextBlock x:Name="lblVehicleInfo" Style="{StaticResource SubtitleText}" Margin="0,0,0,25" TextWrapping="Wrap"></TextBlock>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text=" Проверка документов" Style="{StaticResource LabelText}" Margin="0,0,0,15"></TextBlock>

                    <CheckBox x:Name="chkGibddPermission" Content="Разрешение на выдачу от ГИБДД получено" 
                              FontSize="14" Margin="0,0,0,10" Checked="chkGibddPermission_Checked" Unchecked="chkGibddPermission_Unchecked"></CheckBox>
                    <CheckBox x:Name="chkIdentity" Content="Личность владельца установлена (Паспорт/ВУ)" 
                              FontSize="14" Margin="0,0,0,10" Checked="chkGibddPermission_Checked" Unchecked="chkGibddPermission_Unchecked"></CheckBox>
                    <CheckBox x:Name="chkDocuments" Content="СТС/ПТС проверены и соответствуют данным" 
                              FontSize="14" Checked="chkGibddPermission_Checked" Unchecked="chkGibddPermission_Unchecked"></CheckBox>

                    <TextBlock x:Name="lblValidationStatus" Foreground="#D32F2F" FontSize="12" 
                               Margin="0,10,0,0" Visibility="Collapsed" FontStyle="Italic"></TextBlock>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="Оплата и фиксация" Style="{StaticResource LabelText}" Margin="0,0,0,15"></TextBlock>

                    <DockPanel Margin="0,0,0,15">
                        <TextBlock Text="Сумма к оплате:" DockPanel.Dock="Left" FontSize="14" 
                                   FontWeight="SemiBold" Foreground="#333333" VerticalAlignment="Center"></TextBlock>
                        <TextBlock x:Name="lblTotalAmount" DockPanel.Dock="Right" 
                                   Style="{StaticResource ValueText}" Foreground="#D32F2F"></TextBlock>
                    </DockPanel>

                    <ComboBox x:Name="cmbPaymentMethod" Style="{StaticResource InputComboBoxStyle}" Height="32" Margin="0,0,0,20" SelectedValuePath="MethodId">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MethodName}" Foreground="#333333"></TextBlock>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button x:Name="DeleteButton" Content="Отмена" Style="{StaticResource PrimaryButtonStyle}" Background="#757575" Width="120" Margin="0,0,10,0" 
                                Click="DeleteButton_Click"></Button>
                        <Button x:Name="btnRelease" Content="Сформировать квитанцию и выдать" Style="{StaticResource SuccessButtonStyle}" Width="280" IsEnabled="False" 
                                Click="btnRelease_Click"></Button>
                    </StackPanel>
                    
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
