<Page x:Class="GBDD.Pages.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GBDD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="LoginPage">

    <Grid Background="#E3F2FD">

        <Border Style="{StaticResource CardStyle}" Width="350" HorizontalAlignment="Center" VerticalAlignment="Center">

            <StackPanel>

                <Image Source="/Resourses/Gibdd_logo.png" Width="70" Height="70"  Margin="0,0,0,12" Stretch="Uniform"></Image>

                <TextBlock Text="ГИБДД" FontSize="22" FontWeight="Bold" Foreground="#1565C0" HorizontalAlignment="Center" Margin="0,0,0,3"></TextBlock>

                <TextBlock Text="Система управления штрафстоянкой" FontSize="11" Foreground="#78909C" HorizontalAlignment="Center" Margin="0,0,0,20"></TextBlock>


                <TextBlock Text="Логин" FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,5"></TextBlock>
                <TextBox x:Name="LoginTextBox" Style="{StaticResource InputTextBoxStyle}" Height="35" Margin="0,0,0,12"></TextBox>


                <TextBlock Text="Пароль"  FontSize="12" FontWeight="SemiBold" Foreground="#546E7A" Margin="0,0,0,5"></TextBlock>

                <PasswordBox x:Name="PasswordTextBox" Style="{StaticResource InputPasswordBoxStyle}" Height="35" Margin="0,0,0,15"></PasswordBox>


                <Button x:Name="LoginButton" Content="Войти" Style="{StaticResource PrimaryButtonStyle}" Click="LoginButton_Click" Height="40"  Margin="0,0,0,10"></Button>


            </StackPanel>
            
        </Border>
    </Grid>
</Page>
