<Page x:Class="GBDD.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GBDD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="500" d:DesignWidth="900"
      Title="AdminPage">

    <TabControl Margin="20" Background="Transparent" BorderThickness="0">


        <TabItem Header="Сотрудники" FontSize="14" FontWeight="SemiBold">
            <Grid Background="#F5F7FA" Margin="-2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="123*"></ColumnDefinition>
                    <ColumnDefinition Width="737*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
                <DataGrid x:Name="dgUsers" Grid.Row="0" Margin="10,10,10,10" SelectionMode="Single" 
                          SelectionChanged="dgUsers_SelectionChanged" IsReadOnly="True" Grid.ColumnSpan="2">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="40"></DataGridTextColumn>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="100"></DataGridTextColumn>
                        <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"></DataGridTextColumn>
                        <DataGridTextColumn Header="Роль" Binding="{Binding RoleName}" Width="100"></DataGridTextColumn>
                        <DataGridCheckBoxColumn Header="Активен" Binding="{Binding IsActive}" Width="80"></DataGridCheckBoxColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="10,10,10,10" Grid.ColumnSpan="2">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"></RowDefinition>
                            <RowDefinition Height="Auto"></RowDefinition>

                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                                <ColumnDefinition Width="*"></ColumnDefinition>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="Логин" Style="{StaticResource LabelText}"></TextBlock>
                                <TextBox x:Name="txtLogin" Style="{StaticResource InputTextBoxStyle}" Height="30"></TextBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="ФИО" Style="{StaticResource LabelText}"></TextBlock>
                                <TextBox x:Name="txtFullName" Style="{StaticResource InputTextBoxStyle}" Height="30"></TextBox>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="5">
                                <TextBlock Text="Роль" Style="{StaticResource LabelText}"></TextBlock>
                                <ComboBox x:Name="cmbRole" Style="{StaticResource InputComboBoxStyle}" Height="30" 
                          DisplayMemberPath="RoleName" SelectedValuePath="RoleId"></ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="5">
                                <TextBlock Text="Пароль" Style="{StaticResource LabelText}"></TextBlock>
                                <PasswordBox x:Name="txtPassword" Style="{StaticResource InputPasswordBoxStyle}" Height="30"></PasswordBox>
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10,10,5,5">
                            <Button Content="Очистить" Click="Clear_Click" Style="{StaticResource BaseButtonStyle}" Background="#FF95A5A6" Foreground="White" Padding="10,5" Margin="0,0,10,0"></Button>
                            <Button Content=" Сохранить" Style="{StaticResource SuccessButtonStyle}" Width="120" Click="SaveUser_Click"></Button>
                            <Button Content="Удалить" Style="{StaticResource DangerButtonStyle}" Width="100" Margin="10,0,0,0" Click="DeleteUser_Click"></Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>


        <TabItem Header="Тарифы" FontSize="14" FontWeight="SemiBold" Margin="5,0,0,0">
            <Grid Background="#F5F7FA" Margin="-2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"></ColumnDefinition>
                    <ColumnDefinition Width="17*"></ColumnDefinition>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"></RowDefinition>
                    <RowDefinition Height="Auto"></RowDefinition>
                </Grid.RowDefinitions>
                <DataGrid x:Name="dgTariffs" Grid.Row="0" Margin="10,10,10,10" SelectionMode="Single" 
                          SelectionChanged="dgTariffs_SelectionChanged" IsReadOnly="True" Grid.ColumnSpan="2">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Категория" Binding="{Binding CategoryCode}" Width="80"></DataGridTextColumn>
                        <DataGridTextColumn Header="Название" Binding="{Binding CategoryName}" Width="*"></DataGridTextColumn>
                        <DataGridTextColumn Header="Эвакуация" Binding="{Binding TowCost, StringFormat={}{0:0.00} ₽}" Width="100"></DataGridTextColumn>
                        <DataGridTextColumn Header="Час хранения" Binding="{Binding HourlyRate, StringFormat={}{0:0.00} ₽}" Width="100"></DataGridTextColumn>
                        <DataGridTextColumn Header="Лимит в сутки" Binding="{Binding DailyCap, StringFormat={}{0:0.00} ₽}" Width="100"></DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Border Grid.Row="1" Style="{StaticResource CardStyle}" Margin="10,10,10,10" Grid.ColumnSpan="2">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                            <ColumnDefinition Width="*"></ColumnDefinition>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="5">
                            <TextBlock Text="Категория" Style="{StaticResource LabelText}"></TextBlock>
                            <ComboBox x:Name="cmbTariffCat" Style="{StaticResource InputComboBoxStyle}" Height="30" 
                                      DisplayMemberPath="Name" SelectedValuePath="CategoryId"></ComboBox>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="5">
                            <TextBlock Text="Цена эвакуации (₽)" Style="{StaticResource LabelText}"></TextBlock>
                            <TextBox x:Name="txtTowCost" Style="{StaticResource InputTextBoxStyle}" Height="30"></TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="5">
                            <TextBlock Text="Цена часа хранения (₽)" Style="{StaticResource LabelText}"></TextBlock>
                            <TextBox x:Name="txtHourlyRate" Style="{StaticResource InputTextBoxStyle}" Height="30"></TextBox>
                        </StackPanel>

                        <StackPanel Grid.Column="3" Margin="5">
                            <TextBlock Text="Лимит в сутки (₽)" Style="{StaticResource LabelText}"></TextBlock>
                            <TextBox x:Name="txtDailyCap" Style="{StaticResource InputTextBoxStyle}" Height="30"></TextBox>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                                <Button Content="Обновить тариф" Style="{StaticResource SuccessButtonStyle}" Width="150" Click="SaveTariff_Click"></Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </TabItem>
    </TabControl>
</Page>
