<Page x:Class="GBDD.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GBDD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DashboardPage">

    <Grid Background="#F5F7FA">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="Auto"></RowDefinition>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="15,15,15,5">
            <TextBlock Text="Главный пульт управления" Style="{StaticResource TitleText}"></TextBlock>
            <TextBlock Text="Оперативная информация по штрафстоянке" Style="{StaticResource SubtitleText}"></TextBlock>
        </StackPanel>

        <Grid Grid.Row="1" Margin="15,5,15,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

      
            <Border Grid.Column="0" Style="{StaticResource WidgetStyle}">
                <StackPanel>
                    <TextBlock Text="Загруженность стоянки" Style="{StaticResource LabelText}"></TextBlock>
                    <TextBlock x:Name="txtOccupancy" Text="0 / 100 мест" Style="{StaticResource ValueText}" Margin="0,2,0,0"></TextBlock>
                    <ProgressBar x:Name="pbOccupancy" Style="{StaticResource ProgressBarStyle}" Value="0" Maximum="100" Margin="0,8,0,0"></ProgressBar>
                </StackPanel>
            </Border>


            <Border Grid.Column="1" Style="{StaticResource WidgetStyle}" Margin="8,0">
                <StackPanel>
                    <TextBlock Text="Статистика за сегодня" Style="{StaticResource LabelText}"></TextBlock>
                    <DockPanel Margin="0,5,0,0">
                        <TextBlock Text="Поступило:" DockPanel.Dock="Left" FontSize="12" Foreground="#546E7A"></TextBlock>
                        <TextBlock x:Name="txtArrived" Text="0" DockPanel.Dock="Right" FontWeight="Bold" Foreground="#43A047"></TextBlock>
                    </DockPanel>
                    <DockPanel Margin="0,4,0,0">
                        <TextBlock Text="Выдано:" DockPanel.Dock="Left" FontSize="12" Foreground="#546E7A"></TextBlock>
                        <TextBlock x:Name="txtReleased" Text="0" DockPanel.Dock="Right" FontWeight="Bold" Foreground="#1976D2"></TextBlock>
                    </DockPanel>
                </StackPanel>
            </Border>


            <Border Grid.Column="2" Style="{StaticResource WidgetStyle}" Cursor="Hand" MouseLeftButtonUp="DebtorsWidget_Click" ToolTip="Нажмите, чтобы отфильтровать должников">
                <StackPanel>
                    <TextBlock Text="Должники (&gt;30 дней)" Style="{StaticResource LabelText}"></TextBlock>
                    <TextBlock x:Name="txtDebtors" Text="0 авто" Style="{StaticResource ValueText}" Foreground="#E53935" Margin="0,2,0,0"></TextBlock>
                    <TextBlock Text="Нажмите для просмотра" FontSize="10" Foreground="#90A4AE" Margin="0,6,0,0" TextAlignment="Center"></TextBlock>
                </StackPanel>
            </Border>
        </Grid>


        <Border Grid.Row="2" Background="White" Margin="15,0,15,10" Padding="12" CornerRadius="8" BorderBrush="#E3F2FD" BorderThickness="1">
            <DockPanel>

                <TextBox x:Name="txtSearch" Style="{StaticResource InputTextBoxStyle}"  Width="280" Margin="0,0,10,0" DockPanel.Dock="Left"  
                         ToolTip="Поиск по госномеру, марке или владельцу" KeyDown="txtSearch_KeyDown"></TextBox>

                <Button Content="Найти" Style="{StaticResource PrimaryButtonStyle}"  Width="100" Click="Search_Click" DockPanel.Dock="Right"></Button>


                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" Margin="0,0,10,0">
                    <Button Content="Все" Style="{StaticResource SmallButtonStyle}" Click="Filter_Click" Tag="All" Background="#1976D2" x:Name="btnFilterAll"></Button>
                    <Button Content="На стоянке" Style="{StaticResource SmallButtonStyle}" Click="Filter_Click" Tag="OnLot"></Button>
                    <Button Content="Архив" Style="{StaticResource SmallButtonStyle}" Click="Filter_Click" Tag="Archived"></Button>
                    <Button Content="Должники" Style="{StaticResource SmallButtonStyle}" Click="Filter_Click" Tag="Debtors" Background="#E53935"></Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Style="{StaticResource CardStyle}" Margin="15,0,15,10" Padding="0">
            <DataGrid x:Name="dgCars" SelectionMode="Single" MouseDoubleClick="dgCars_MouseDoubleClick" RowDetailsVisibilityMode="Collapsed">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Госномер" Binding="{Binding LicensePlate}" Width="90" FontSize="12" FontWeight="SemiBold"></DataGridTextColumn>
                    <DataGridTextColumn Header="Марка / Модель" Binding="{Binding MakeModel}" Width="140"></DataGridTextColumn>
                    <DataGridTextColumn Header="Владелец" Binding="{Binding OwnerName}" Width="150"></DataGridTextColumn>
                    <DataGridTextColumn Header="Дата заезда" Binding="{Binding IntakeDate, StringFormat=dd.MM.yyyy}" Width="90"></DataGridTextColumn>
                    <DataGridTextColumn Header="Дней" Binding="{Binding DaysOnLot}" Width="60" CellStyle="{StaticResource {x:Type DataGridCell}}"></DataGridTextColumn>
                    <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="#546E7A"></Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding StatusName}" Value="На участке">
                                        <Setter Property="Foreground" Value="#43A047"></Setter>
                                        <Setter Property="FontWeight" Value="SemiBold"></Setter>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding StatusName}" Value="Архив">
                                        <Setter Property="Foreground" Value="#9E9E9E"></Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Header="Действия" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="✐" Style="{StaticResource SmallButtonStyle}" ToolTip="Редактировать" Click="EditCar_Click" Tag="{Binding RegistryId}"></Button>
                                    <Button Content="📦" Style="{StaticResource SmallButtonStyle}" Background="#E53935" 
                                            ToolTip="В архив" Click="ArchiveCar_Click" Tag="{Binding RegistryId}"></Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <Border Grid.Row="4" Margin="15,0,15,15">
            <Button  x:Name="btnAcceptCar" Content=" Принять новый автомобиль" Style="{StaticResource SuccessButtonStyle}" 
                    Height="48" FontSize="15" Click="AcceptCar_Click"/>
        </Border>
    </Grid>
</Page>
