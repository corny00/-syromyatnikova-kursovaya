<Page x:Class="GBDD.Pages.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:GBDD.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="1200" d:DesignWidth="1000"
      Title="ReportsPage">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0,0,15,0" Background="#F5F7FA">
        <StackPanel Margin="20">

            <DockPanel Margin="0,0,0,20">
                <TextBlock Text="Отчеты" Style="{StaticResource TitleText}"></TextBlock>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Экспорт в Excel" Style="{StaticResource PrimaryButtonStyle}" 
                            Width="150" Margin="10,0,0,0" Click="Export_Click"></Button>
                </StackPanel>
            </DockPanel>

            <Border Style="{StaticResource CardStyle}" Padding="15">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Период:" FontWeight="SemiBold" Margin="0,0,10,0" VerticalAlignment="Center"></TextBlock>
                    <DatePicker x:Name="dpFrom" Width="120" Margin="0,0,10,0"></DatePicker>
                    <TextBlock Text="—"></TextBlock>
                    <DatePicker x:Name="dpTo" Width="120" Margin="10,0,20,0"></DatePicker>
                    <Button Content="Сформировать" Style="{StaticResource SuccessButtonStyle}" 
                            Width="140" Click="GenerateReports_Click"></Button>
                    <Button Content="Сбросить" Style="{StaticResource PrimaryButtonStyle}" Background="#757575" 
                            Width="100" Margin="10,0,0,0" Click="ResetFilters_Click"></Button>
                </StackPanel>
            </Border>


            <Grid Margin="0,10,0,20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource WidgetStyle}" BorderBrush="#43A047" BorderThickness="2,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Всего получено" Style="{StaticResource LabelText}"></TextBlock>
                        <TextBlock x:Name="lblTotalRevenue" Style="{StaticResource ValueText}" Text="0 ₽"></TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Style="{StaticResource WidgetStyle}" BorderBrush="#1976D2" BorderThickness="2,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Принято авто" Style="{StaticResource LabelText}"></TextBlock>
                        <TextBlock x:Name="lblCarsIn" Style="{StaticResource ValueText}" Text="0"></TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Style="{StaticResource WidgetStyle}" BorderBrush="#1565C0" BorderThickness="2,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Выдано авто" Style="{StaticResource LabelText}"></TextBlock>
                        <TextBlock x:Name="lblCarsOut" Style="{StaticResource ValueText}" Text="0"></TextBlock>
                    </StackPanel>
                </Border>
                <Border Grid.Column="3" Style="{StaticResource WidgetStyle}" BorderBrush="#E53935" BorderThickness="2,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Средний срок" Style="{StaticResource LabelText}"></TextBlock>
                        <TextBlock x:Name="lblAvgDays" Style="{StaticResource ValueText}" Text="0 дн."></TextBlock>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="Финансовый отчет" Style="{StaticResource LabelText}" Margin="0,0,0,12"></TextBlock>
                    <DataGrid x:Name="dgFinance" AutoGenerateColumns="False" Height="150">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Способ оплаты" Binding="{Binding MethodName}" Width="*"></DataGridTextColumn>
                            <DataGridTextColumn Header="Количество" Binding="{Binding Count}" Width="100"></DataGridTextColumn>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat=C}" Width="150"></DataGridTextColumn>
                            <DataGridTextColumn Header="Доля" Binding="{Binding Percent, StringFormat={}{0:0}%}" Width="100"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>


            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                    <ColumnDefinition Width="*"></ColumnDefinition>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource CardStyle}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="Топ инспекторов" Style="{StaticResource LabelText}" Margin="0,0,0,12"></TextBlock>
                        <DataGrid x:Name="dgInspectors" AutoGenerateColumns="False" Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="*"></DataGridTextColumn>
                                <DataGridTextColumn Header="Оформлено" Binding="{Binding Count}" Width="100"></DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>


                <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="Топ марок авто" Style="{StaticResource LabelText}" Margin="0,0,0,12"></TextBlock>
                        <DataGrid x:Name="dgMakes" AutoGenerateColumns="False" Height="200">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Марка" Binding="{Binding MakeName}" Width="*"></DataGridTextColumn>
                                <DataGridTextColumn Header="Количество" Binding="{Binding Count}" Width="100"></DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Детализация по эвакуациям" Style="{StaticResource LabelText}" Margin="0,0,0,12"></TextBlock>
                    <DataGrid x:Name="dgDetails" AutoGenerateColumns="False" Height="250">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding IntakeDate, StringFormat=dd.MM.yyyy}" Width="90"></DataGridTextColumn>
                            <DataGridTextColumn Header="Госномер" Binding="{Binding LicensePlate}" Width="100"></DataGridTextColumn>
                            <DataGridTextColumn Header="Марка" Binding="{Binding MakeModel}" Width="140"></DataGridTextColumn>
                            <DataGridTextColumn Header="Владелец" Binding="{Binding OwnerName}" Width="*"></DataGridTextColumn>
                            <DataGridTextColumn Header="Сумма" Binding="{Binding Amount, StringFormat=C}" Width="120"></DataGridTextColumn>
                            <DataGridTextColumn Header="Статус" Binding="{Binding StatusName}" Width="100"></DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
